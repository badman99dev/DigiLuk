rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isMemberFromData(data) {
      return isAuthenticated() && request.auth.uid in data.memberUids;
    }
    function isAdminFromData(data) {
      return isAuthenticated() && isMemberFromData(data) && (
        request.auth.uid == data.createdByUid ||
        request.auth.uid in data.managerUids
      );
    }
    function trustData(trustId) {
      return get(/databases/$(database)/documents/trusts/$(trustId)).data;
    }
    function isMemberOfTrust(trustId) {
      return isMemberFromData(trustData(trustId));
    }
    function isAdminOfTrust(trustId) {
      return isAdminFromData(trustData(trustId));
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/profile/{document=**} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/parties/{partyId} {
      allow read, write, create, delete: if isOwner(userId);
    }
    match /users/{userId}/parties/{partyId}/entries/{entryId} {
      allow read, write, create, delete: if isOwner(userId);
    }
    match /users/{userId}/parties/{partyId}/auditLogs/{auditLogId} {
      allow read, create: if isOwner(userId);
      allow update, delete: if false;
    }
    match /users/{userId}/items/{itemId} {
      allow read, write, create, delete: if isOwner(userId);
    }
    match /users/{userId}/invoices/{invoiceId} {
      allow read, write, create, delete: if isOwner(userId);
    }
    match /users/{userId}/bills/{billId} {
      allow read, write, create, delete: if isOwner(userId);
    }
    match /users/{userId}/reports/{reportId} {
      allow read, write, create, delete: if isOwner(userId);
    }
    match /users/{userId}/stocks/{stockId} {
      allow read, write, create, delete: if isOwner(userId);
    }
    match /users/{userId}/transactions/{transactionId} {
      allow read, write, create, delete: if isOwner(userId);
    }
    match /users/{userId}/notifications/{notificationId} {
      allow read, write, create, delete: if isOwner(userId);
    }
    match /users/{userId}/settings/{document=**} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/notifications/{notificationId} {
      allow read, delete: if isOwner(userId);
      allow create: if false;
    }

    match /trusts/{trustId} {
      allow create: if isAuthenticated();
      allow read: if isMemberFromData(resource.data);
      allow update, delete: if isAdminFromData(resource.data);
    }
    match /trusts/{trustId}/members/{memberId} {
      allow read, write, create, delete: if isMemberOfTrust(trustId);
    }
    match /trusts/{trustId}/transactions/{transactionId} {
      allow read: if isMemberOfTrust(trustId);
      allow create: if isMemberOfTrust(trustId);
      allow update, delete: if isAdminOfTrust(trustId) ||
        (isMemberOfTrust(trustId) && request.auth.uid == resource.data.addedBy);
    }
    match /trusts/{trustId}/groups/{groupId} {
      allow read: if isMemberOfTrust(trustId);
      allow write, create, delete: if isAdminOfTrust(trustId);
    }
    match /trusts/{trustId}/notifications/{notificationId} {
      allow read: if isMemberOfTrust(trustId) && request.auth.uid == resource.data.userId;
      allow create: if isAdminOfTrust(trustId);
      allow update: if isAdminOfTrust(trustId) ||
        (isMemberOfTrust(trustId) && request.auth.uid == resource.data.userId);
      allow delete: if isAdminOfTrust(trustId) ||
        (isMemberOfTrust(trustId) && request.auth.uid == resource.data.userId);
    }
    match /trusts/{trustId}/chats/{messageId} {
      allow read: if isMemberOfTrust(trustId);
      allow create: if isMemberOfTrust(trustId);
      allow update, delete: if isAdminOfTrust(trustId) ||
        (isMemberOfTrust(trustId) && request.auth.uid == resource.data.senderId);
    }
    match /trusts/{trustId}/audits/{auditId} {
      allow read: if isMemberOfTrust(trustId);
      allow create: if isMemberOfTrust(trustId);
      allow update, delete: if false;
    }
    match /trusts/{trustId}/announcements/{announcementId} {
      allow read: if isMemberOfTrust(trustId);
      allow create, update, delete: if isAdminOfTrust(trustId);
    }
    match /trusts/{trustId}/roles/{roleId} {
      allow read: if isMemberOfTrust(trustId);
      allow write, create, delete: if isAdminOfTrust(trustId);
    }
    match /trusts/{trustId}/documents/{documentId} {
      allow read: if isMemberOfTrust(trustId);
      allow write, create, delete: if isAdminOfTrust(trustId) ||
        (isMemberOfTrust(trustId) && request.auth.uid == resource.data.uploadedBy);
    }
    match /trusts/{trustId}/events/{eventId} {
      allow read: if isMemberOfTrust(trustId);
      allow write, create, delete: if isAdminOfTrust(trustId) ||
        (isMemberOfTrust(trustId) && request.auth.uid == resource.data.createdBy);
    }
    match /trusts/{trustId}/votes/{voteId} {
      allow read: if isMemberOfTrust(trustId);
      allow write, create: if isMemberOfTrust(trustId);
      allow delete: if isAdminOfTrust(trustId) ||
        (isMemberOfTrust(trustId) && request.auth.uid == resource.data.voterId);
    }
    match /trusts/{trustId}/reports/{reportId} {
      allow read: if isMemberOfTrust(trustId);
      allow write, create, delete: if isAdminOfTrust(trustId);
    }
    match /trusts/{trustId}/settings/{document=**} {
      allow read: if isMemberOfTrust(trustId);
      allow write: if isAdminOfTrust(trustId);
    }
    match /trusts/{trustId}/logs/{logId} {
      allow read: if isMemberOfTrust(trustId);
      allow create: if isMemberOfTrust(trustId);
      allow update, delete: if false;
    }
  }
}
